// ============================================================================
// BEST PRACTICES
// ============================================================================
//
// 1. Keep handlers thin - delegate to app_services for complex logic
// 2. Always verify tenant ownership for multi-tenant operations
// 3. Use middleware.GetSessionData() for authentication
// 4. Return errors directly - error middleware handles formatting
// 5. Use repository functions for reads, mutation functions for writes
// 6. Log important operations with h.app.Logger()
// 7. Validate inputs (supplement oapi-codegen's validation as needed)
// 8. Follow REST conventions for status codes:
//    - 200 OK: Successful GET, PUT, PATCH
//    - 201 Created: Successful POST
//    - 204 No Content: Successful DELETE
//    - 400 Bad Request: Validation errors
//    - 401 Unauthorized: Authentication required
//    - 403 Forbidden: Authenticated but not authorized
//    - 404 Not Found: Resource doesn't exist
//    - 500 Internal Server Error: Unexpected errors
//
// 9. For paginated endpoints, use repository.PaginationParams
// 10. Always include tenant_id in WHERE clauses for multi-tenant apps

// ============================================================================
// ANTI-PATTERNS TO AVOID
// ============================================================================
//
// ❌ Don't write business logic in handlers
// ❌ Don't bypass tenant isolation checks
// ❌ Don't return database errors directly (wrap them)
// ❌ Don't mix repository and mutation logic in one handler
// ❌ Don't forget to validate user input
// ❌ Don't expose internal IDs or sensitive data
// ❌ Don't use raw SQL in handlers (use repository/mutation layers)

// Prevent unused import errors in example file
var (
	_ = config.App{}
	_ = oapi.GetApiV1UserRequestObject{}
	_ = repository.GetUserByID
	_ = mutation.CreateUser
	_ = middleware.GetSessionData
	_ = errors.New
	_ = uuid.New
)
