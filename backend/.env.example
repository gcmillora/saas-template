# App
APP_ENV=local
APP_SECRET=change-me-to-a-random-secret
APP_BASE_URL=http://localhost:8009

# Server
SERVER_PORT=8008

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/database?sslmode=disable

# Session
SESSION_SECRET=change-me-to-a-random-secret

# Logging
LOG_LEVEL=debug

# OAuth (optional - leave empty to disable)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
